{
  "heading-increment": {
    "front_matter_title": "^\\s*(name|title)\\s*[:=]"
  },
  "heading-style": true,
  "header-style": {
    "style": "atx"
  },
  "ul-style": {
    "style": "asterisk"
  },
  "list-indent": true,
  "ul-indent": {
    "indent": 2,
    "start_indent": 4,
    "start_indented": false
  },
  "no-trailing-spaces": {
    "br_spaces": 2,
    "code_blocks": false,
    "list_item_empty_lines": false,
    "strict": false
  },
  "no-hard-tabs": {
    "code_blocks": true,
    "ignore_code_languages": [],
    "spaces_per_tab": 2
  },
  "no-reversed-links": true,
  "no-multiple-blanks": {
    "maximum": 1
  },
  "line-length": {
    "code_blocks": false,
    "headings": false,
    "line_length": 100000,
    "stern": false,
    "strict": false,
    "tables": false
  },
  "commands-show-output": false,
  "no-missing-space-atx": true,
  "no-multiple-space-atx": true,
  "blanks-around-headers": {
    "lines_above": 1,
    "lines_below": 1
  },
  "header-start-left": true,
  "no-duplicate-heading": {
    "siblings_only": true
  },
  "single-h1": {
    "level": 1,
    "front_matter_title": "^\\s*(name|title)\\s*[:=]"
  },
  "no-trailing-punctuation": {
    "punctuation": ".,;:"
  },
  "no-multiple-space-blockquote": {
    "list_items": true
  },
  "no-blanks-blockquote": true,
  "ol-prefix": {
    "style": "ordered"
  },
  "list-marker-space": {
    "ul_single": 1,
    "ol_single": 1,
    "ul_multi": 1,
    "ol_multi": 1
  },
  "blanks-around-fences": {
    "list_items": true
  },
  "blanks-around-lists": true,
  "no-inline-html": {
    "allowed_elements": [
      "a",
      "b",
      "br",
      "code",
      "details",
      "div",
      "img",
      "li",
      "nobr",
      "ol",
      "p",
      "pre",
      "span",
      "summary",
      "ul"
    ],
    "table_allowed_elements": []
  },
  "no-bare-urls": true,
  "hr-style": {
    "style": "consistent"
  },
  "no-emphasis-as-heading": {
    "punctuation": ".,;:!?"
  },
  "no-space-in-emphasis": true,
  "no-space-in-code": true,
  "no-space-in-links": true,
  "fenced-code-language": true,
  "first-line-h1": {
    "allow_preamble": true,
    "front_matter_title": "^\\s*(name|title)\\s*[:=]"
  },
  "no-empty-links": true,
  "required-headings": false,
  "proper-names": {
    "names": [],
    "html_elements": false,
    "code_blocks": false
  },
  "no-alt-text": true,
  "code-block-style": {
    "style": "fenced"
  },
  "single-trailing-newline": true,
  "code-fence-style": {
    "style": "backtick"
  },
  "emphasis-style": {
    "style": "underscore"
  },
  "strong-style": {
    "style": "asterisk"
  },
  "link-fragments": {
    "ignore_case": false,
    "ignored_pattern": ""
  }
}
